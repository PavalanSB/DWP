# Copy this file to .env and fill in your values.
# Get Google OAuth credentials: https://console.cloud.google.com/
#   APIs & Services -> Credentials -> Create OAuth 2.0 Client ID (Web application)
#   Add redirect URI: http://127.0.0.1:5000/auth/google/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Facebook. Get from https://developers.facebook.com/
#   Add Valid OAuth Redirect URI: http://127.0.0.1:5000/auth/facebook/callback

# FACEBOOK_APP_ID=your-app-id
# FACEBOOK_APP_SECRET=your-app-secret
