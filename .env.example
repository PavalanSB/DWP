# Copy this file to .env and fill in your values.
# Get Google OAuth credentials: https://console.cloud.google.com/
#   APIs & Services -> Credentials -> Create OAuth 2.0 Client ID (Web application)
#   Authorized redirect URIs (add both exactly):
#     http://localhost:5000/auth/google/callback
#     http://localhost:5000/settings/delete-account/confirm/google
#   Use the app at http://localhost:5000 (not 127.0.0.1) so OAuth matches.

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth redirect base (must match Google Console). Default below is correct for local.
# OAUTH_BASE_URL=http://localhost:5000

# (Facebook login has been removed from this project.)
